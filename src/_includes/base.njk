<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ pageDescription or site.description }}">
  {% set root = page.url | rootPath %}
  <link rel="icon" type="image/jpeg" href="{{ root }}/assets/images/favicon.jpg">
  <link rel="stylesheet" href="{{ root }}/assets/css/style.css">
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS" href="{{ root }}/feed.xml">
</head>
<body>

  <div id="flex-container">

    <!-- Fixed Sidebar -->
    <div id="sidebar">

      <a href="{{ root }}/" class="site-branding">
        <img src="{{ root }}/assets/images/logo.png" alt="{{ site.title }}" class="site-logo">
        <div class="site-title">{{ site.title }}</div>
      </a>

      <!-- Search -->
      <div class="sidebar-section">
        <h2>Search</h2>
        <form class="search-form" action="{{ root }}/search/" method="get" onsubmit="return sidebarSearch(event)">
          <input type="text" id="sidebarSearchInput" placeholder="Search…" autocomplete="off">
          <button type="submit" aria-label="Search">&#128269;</button>
        </form>
      </div>

      <!-- Subscribe -->
      <div class="sidebar-section" id="subscribeSection">
        <h2>Subscribe</h2>
        <p class="sidebar-small" style="margin:0 0 10px;color:#666">Get early access + exclusive content.</p>

        <form class="subscribe-form" onsubmit="return handleSubscribe(event)" id="subscribeForm">
          <input type="email" name="email" placeholder="me@email.com — press Enter" required autocomplete="email">
        </form>

        <div class="sidebar-small" id="signupMsg" style="display:none;"></div>

        <form id="subscribeProfile" style="display:none;margin-top:10px;border-top:1px dashed #ddd;padding-top:10px" onsubmit="return handleSubscribeProfile(event)">
          <p class="sidebar-small" style="margin:0 0 8px;color:#333"><strong>Tell us a bit more</strong> <span style="color:#888">(optional)</span></p>

          <label class="sub-label">Name</label>
          <input type="text" name="name" placeholder="Your name" autocomplete="name">

          <label class="sub-label" style="margin-top:8px">Age range</label>
          <select name="age_range">
            <option value="">— skip —</option>
            <option>18-24</option>
            <option>25-34</option>
            <option>35-44</option>
            <option>45-54</option>
            <option>55-64</option>
            <option>65+</option>
          </select>

          <label class="sub-label" style="margin-top:8px">Interests</label>
          <div class="sub-chips">
            <label class="sub-chip"><input type="checkbox" name="interests" value="Creativity &amp; Writing"> Creativity &amp; Writing</label>
            <label class="sub-chip"><input type="checkbox" name="interests" value="Business &amp; Entrepreneurship"> Business</label>
            <label class="sub-chip"><input type="checkbox" name="interests" value="Investing &amp; Money"> Investing</label>
            <label class="sub-chip"><input type="checkbox" name="interests" value="Parenting &amp; Family"> Parenting</label>
            <label class="sub-chip"><input type="checkbox" name="interests" value="Philosophy &amp; Ideas"> Philosophy</label>
            <label class="sub-chip"><input type="checkbox" name="interests" value="Personal Development"> Personal growth</label>
            <label class="sub-chip"><input type="checkbox" name="interests" value="Technology"> Technology</label>
            <label class="sub-chip"><input type="checkbox" name="interests" value="Health &amp; Habits"> Health</label>
          </div>

          <div style="display:flex;gap:6px;margin-top:10px">
            <button type="submit">Save</button>
            <button type="button" onclick="document.getElementById('subscribeProfile').style.display='none'" style="background:transparent;border:0;color:#888;cursor:pointer;font-size:12px">Skip</button>
          </div>
        </form>
      </div>


      <!-- Navigation -->
      <div class="sidebar-section">
        <h2>Navigate</h2>
        <div class="sidebar-nav">
          <a href="{{ root }}/">Home</a>
          <a href="{{ root }}/archive/">Archive</a>
          <a href="{{ root }}/categories/">Categories</a>
          <a href="{{ root }}/search/">Search All Posts</a>
          <a href="{{ root }}/about/">About</a>
          <a href="{{ root }}/feed.xml">RSS Feed</a>
        </div>
      </div>

    </div>

    <!-- Content Area -->
    <div id="content-container">
      <main id="content">
        {{ content | safe }}
      </main>
    </div>

  </div>

  <script src="{{ root }}/assets/js/app.js"></script>

  <script>
    (function(){
      try {
        var body = JSON.stringify({url: location.pathname, ref: document.referrer || ''});
        var blob = new Blob([body], {type: 'text/plain'});
        if (navigator.sendBeacon) {
          navigator.sendBeacon('https://app.arnavnavon.com/track', blob);
        } else {
          fetch('https://app.arnavnavon.com/track', {method: 'POST', body: blob, keepalive: true, mode: 'no-cors'}).catch(function(){});
        }
      } catch(e) {}
    })();
  </script>

</body>
</html>
