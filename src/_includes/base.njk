<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ pageDescription or site.description }}">
  {% set root = page.url | rootPath %}
  <link rel="icon" type="image/jpeg" href="{{ root }}/assets/images/favicon.jpg">
  <link rel="stylesheet" href="{{ root }}/assets/css/style.css">
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS" href="{{ root }}/feed.xml">
</head>
<body>

  <div id="flex-container">

    <!-- Fixed Sidebar -->
    <div id="sidebar">

      <a href="{{ root }}/" class="site-branding">
        <img src="{{ root }}/assets/images/logo.png" alt="{{ site.title }}" class="site-logo">
        <div class="site-title">{{ site.title }}</div>
      </a>

      <!-- Search -->
      <div class="sidebar-section">
        <h2>Search</h2>
        <form class="search-form" action="{{ root }}/search/" method="get" onsubmit="return sidebarSearch(event)">
          <input type="text" id="sidebarSearchInput" placeholder="Search…" autocomplete="off">
          <button type="submit" aria-label="Search">&#128269;</button>
        </form>
      </div>

      <!-- Subscribe -->
      <div class="sidebar-section">
        <h2>Subscribe</h2>
        <form class="subscribe-form" onsubmit="return handleSubscribe(event)">
          <input type="email" placeholder="me@email.com" required>
          <button type="submit">Sign Up</button>
        </form>
        <div class="sidebar-small" id="signupMsg" style="display:none;"></div>
      </div>

      <!-- Navigation -->
      <div class="sidebar-section">
        <h2>Navigate</h2>
        <div class="sidebar-nav">
          <a href="{{ root }}/">Home</a>
          <a href="{{ root }}/archive/">Archive</a>
          <a href="{{ root }}/categories/">Categories</a>
          <a href="{{ root }}/search/">Search All Posts</a>
          <a href="{{ root }}/about/">About</a>
          <a href="{{ root }}/feed.xml">RSS Feed</a>
        </div>
      </div>

    </div>

    <!-- Content Area -->
    <div id="content-container">
      <main id="content">
        {{ content | safe }}
      </main>
    </div>

  </div>

  <script src="{{ root }}/assets/js/app.js"></script>

  <script>
    (function(){
      try {
        var body = JSON.stringify({url: location.pathname, ref: document.referrer || ''});
        var blob = new Blob([body], {type: 'text/plain'});
        if (navigator.sendBeacon) {
          navigator.sendBeacon('https://app.arnavnavon.com/track', blob);
        } else {
          fetch('https://app.arnavnavon.com/track', {method: 'POST', body: blob, keepalive: true, mode: 'no-cors'}).catch(function(){});
        }
      } catch(e) {}
    })();
  </script>

  <!-- arnavnavon-auth-widget -->
  <div id="aw-root" style="position:fixed;bottom:16px;right:16px;z-index:9999;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">
    <button id="aw-open" style="background:#111;color:#fff;border:0;padding:10px 18px;border-radius:999px;font-size:13px;font-weight:600;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.12)">✉️ Sign up</button>
    <div id="aw-panel" style="display:none;position:absolute;bottom:52px;right:0;background:#fff;border:1px solid #e5e5e5;border-radius:8px;padding:18px;width:300px;box-shadow:0 6px 24px rgba(0,0,0,0.12)">
      <h3 style="margin:0 0 8px;font-size:16px">Join arnavnavon</h3>
      <p style="margin:0 0 12px;font-size:13px;color:#555;line-height:1.5">Get early access to new posts, exclusive content, and first access to Q&amp;A &amp; forum when they launch.</p>
      <form id="aw-form" style="display:flex;gap:6px">
        <input id="aw-email" type="email" required placeholder="you@example.com" style="flex:1;padding:8px 10px;border:1px solid #d4d4d4;border-radius:4px;font-size:13px;font-family:inherit">
        <button type="submit" style="background:#111;color:#fff;border:0;padding:8px 14px;border-radius:4px;font-size:13px;font-weight:600;cursor:pointer">Join</button>
      </form>
      <div id="aw-msg" style="font-size:12px;color:#555;margin-top:10px;min-height:16px"></div>
      <div id="aw-signedin" style="display:none;font-size:13px;color:#155724;background:#d4edda;padding:8px 10px;border-radius:4px;margin-top:10px"></div>
    </div>
  </div>
  <script>
    (function(){
      var API='https://app.arnavnavon.com';
      var open=document.getElementById('aw-open');
      var panel=document.getElementById('aw-panel');
      var form=document.getElementById('aw-form');
      var msg=document.getElementById('aw-msg');
      var signedIn=document.getElementById('aw-signedin');
      open.onclick=function(){ panel.style.display = panel.style.display==='block' ? 'none' : 'block'; };
      // Auto-hide the open button if already signed in
      fetch(API+'/auth/me',{credentials:'include'}).then(function(r){return r.json();}).then(function(d){
        if(d && d.ok){
          open.textContent='✓ You\'re in';
          panel.style.display='none';
          form.style.display='none';
          signedIn.textContent='Signed in as '+d.email;
          signedIn.style.display='block';
        }
      }).catch(function(){});
      form.onsubmit=function(e){
        e.preventDefault();
        msg.textContent='Sending you a link…';
        msg.style.color='#555';
        var email=document.getElementById('aw-email').value.trim();
        fetch(API+'/auth/magic-link',{
          method:'POST',
          credentials:'include',
          headers:{'Content-Type':'text/plain'},
          body: JSON.stringify({email:email, source:location.pathname})
        }).then(function(r){return r.json();}).then(function(d){
          if(d && d.ok){
            msg.textContent='Check your inbox — click the link to sign in.';
            msg.style.color='#155724';
          } else {
            msg.textContent=(d && d.error) || 'Something went wrong — try again.';
            msg.style.color='#842029';
          }
        }).catch(function(){
          msg.textContent='Network error — try again.';
          msg.style.color='#842029';
        });
      };
    })();
  </script>
</body>
</html>
