---
layout: base.njk
pagination:
  data: collections.posts
  size: 10
  alias: pagePosts
permalink: "{% if pagination.pageNumber > 0 %}/page/{{ pagination.pageNumber + 1 }}/{% else %}/{% endif %}"
---

<div class="fade-in">
{% for post in pagePosts %}
  <div class="post">
    <h2 class="post-title"><a href="{{ page.url | rootPath }}{{ post.url }}">{{ post.data.title }}</a></h2>
    <div class="post-content">
      {{ post.templateContent | safe }}
    </div>
  </div>
  <div class="post-footer">
    <div class="post-date">{{ post.date | upperDate }}</div>
    {% if post.data.categories and post.data.categories.length %}
    <div class="post-categories">
      {% for cat in post.data.categories %}
      <a href="{{ page.url | rootPath }}/categories/{{ cat | slugify }}/" class="category-tag">{{ cat }}</a>
      {% endfor %}
    </div>
    {% endif %}
    <div class="post-share">
      <a href="#" title="Share on Facebook"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.77 7.46H14.5v-1.9c0-.9.6-1.1 1-1.1h3V.5h-4.33C10.24.5 9.5 3.44 9.5 5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4z"/></svg></a>
      <a href="https://x.com/adonewer" target="_blank" title="Share on Twitter"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.44 4.83c-.8.37-1.5.38-2.22.02.93-.56.98-.96 1.32-2.02-.88.52-1.86.9-2.9 1.1-.82-.88-2-1.43-3.3-1.43-2.5 0-4.55 2.04-4.55 4.54 0 .36.03.7.1 1.04-3.77-.2-7.12-2-9.36-4.75-.4.67-.6 1.45-.6 2.3 0 1.56.8 2.95 2 3.77-.74-.03-1.44-.23-2.05-.57v.06c0 2.2 1.56 4.03 3.64 4.44-.67.2-1.37.2-2.06.08.58 1.8 2.26 3.12 4.25 3.16C5.78 18.1 3.37 18.74 1 18.46c2 1.3 4.4 2.04 6.97 2.04 8.35 0 12.92-6.92 12.92-12.93 0-.2 0-.4-.02-.6.9-.63 1.96-1.22 2.56-2.14z"/></svg></a>
      <a href="#" title="Share on LinkedIn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.5 21.5h-5v-13h5v13zM4 6.5C2.5 6.5 1.5 5.3 1.5 4s1-2.4 2.5-2.4c1.5 0 2.4 1.1 2.5 2.4 0 1.3-1 2.5-2.5 2.5zm11.5 15h-5v-7c0-1.7-.5-2.8-2-2.8-1.1 0-1.8.8-2 1.5-.1.3-.1.7-.1 1v7.3h-5V8.5h5v2c.7-1 1.8-2.5 4.3-2.5 3.2 0 5.3 2 5.3 6.5v7z"/></svg></a>
      <a href="#" title="Copy link" onclick="copyLink(this);return false;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></a>
    </div>
  </div>
{% endfor %}
</div>

{% if pagination.pages.length > 1 %}
<div class="pagination">
  {% if pagination.href.previous %}<a href="{{ pagination.href.previous }}">← Newer</a>{% endif %}
  {% for pageEntry in pagination.pages %}
    {% if loop.index0 === pagination.pageNumber %}
      <span class="current">{{ loop.index }}</span>
    {% else %}
      <a href="{{ pagination.hrefs[loop.index0] }}">{{ loop.index }}</a>
    {% endif %}
  {% endfor %}
  {% if pagination.href.next %}<a href="{{ pagination.href.next }}">Older →</a>{% endif %}
</div>
{% endif %}
